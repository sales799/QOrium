{
  "name": "@qorium/testforge-orchestrator",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "QOrium TestForge QA Pipeline orchestrator. PM2 fork-mode worker per governance/TestForge-QA-Pipeline-v1.md.",
  "main": "./dist/index.js",
  "bin": {
    "qorium-testforge-orchestrator": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "dev": "tsx watch src/cli.ts --once",
    "start": "node dist/cli.js --once",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@qorium/db": "workspace:*",
    "pino": "^9.5.0"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}

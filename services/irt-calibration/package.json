{
  "name": "@qorium/irt-calibration",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "QOrium IRT Calibration Pipeline v0. Nightly cron @ 03:00 IST per infra/IRT-Calibration-Pipeline-v0-Spec.md (Constitution SO-21).",
  "main": "./dist/index.js",
  "bin": {
    "qorium-irt-calibration": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "dev": "tsx watch src/cli.ts --once",
    "start": "node dist/cli.js --once",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@qorium/db": "workspace:*",
    "pino": "^9.5.0"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}

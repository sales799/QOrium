{
  "name": "@qorium/setu",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "QOrium Setu (Sanskrit: bridge) — exposes the build-state of the repo as a stable JSON + REST surface that the external QOrium Live Progress Dashboard MCP can pull from. One-direction: repo → dashboard.",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "snapshot": "tsx src/cli.ts snapshot",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "express": "^5.0.1",
    "helmet": "^8.0.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}

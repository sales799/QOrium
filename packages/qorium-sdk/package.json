{
  "name": "@qorium/sdk",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "QOrium TypeScript SDK — typed client for the v0 public API surface (ReadyBank, JD-Forge, Stack-Vault, Webhooks, SSO, Audit-Log).",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}

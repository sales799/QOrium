{
  "name": "@qorium/ats-connectors",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "QOrium ATS connector framework + per-vendor adapters per infra/ATS-Connector-Framework-v0.md.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",

{
  "name": "@qorium/smoke",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "QOrium deployment readiness smoke runner. Verifies infra + services + import graph before Customer Zero activation.",
  "main": "./dist/index.js",
  "bin": {
    "qorium-smoke": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "smoke": "tsx src/cli.ts ready",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@qorium/db": "workspace:*",
    "@qorium/irt-calibration": "workspace:*",
    "@qorium/judge0-orchestrator": "workspace:*",
    "@qorium/leak-crawler": "workspace:*",
    "@qorium/testforge-orchestrator": "workspace:*"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}

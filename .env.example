# =============================================================================
# QOrium environment variables — example file
# Copy to .env and fill in real values. Never commit .env.
# =============================================================================

# Runtime --------------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=debug

# Postgres -------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=qorium
POSTGRES_USER=qorium
POSTGRES_PASSWORD=qorium_dev_password
DATABASE_URL=postgresql://qorium:qorium_dev_password@localhost:5432/qorium

# Redis ----------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Object storage (MinIO in dev, R2 in prod) ----------------------------------
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=qorium_dev_access
S3_SECRET_KEY=qorium_dev_secret
S3_BUCKET=qorium-dev

# Judge0 (code execution sandbox) --------------------------------------------
JUDGE0_URL=http://localhost:2358
JUDGE0_AUTH_TOKEN=

# AI providers ---------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-pro

# Anti-Leak Engine -----------------------------------------------------------
SERPER_API_KEY=

# Auth -----------------------------------------------------------------------
JWT_SECRET=replace_me_with_long_random_string
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Observability --------------------------------------------------------------
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
GRAFANA_CLOUD_API_KEY=

# Service ports (dev) --------------------------------------------------------
READYBANK_PORT=4001
JDFORGE_PORT=4002
STACKVAULT_PORT=4003
ANTILEAK_PORT=4004
CONTENT_ENGINE_PORT=4005
GATEWAY_PORT=4000

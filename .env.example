# =============================================================================
# QOrium environment variables — example file
# Copy to .env and fill in real values. Never commit .env.
# =============================================================================

# Runtime --------------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=debug

# Postgres -------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=qorium
POSTGRES_USER=qorium
POSTGRES_PASSWORD=qorium_dev_password
DATABASE_URL=postgresql://qorium:qorium_dev_password@localhost:5432/qorium

# Redis ----------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Object storage (MinIO in dev, R2 in prod) ----------------------------------
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=qorium_dev_access
S3_SECRET_KEY=qorium_dev_secret
S3_BUCKET=qorium-dev

# Judge0 (code execution sandbox) --------------------------------------------
JUDGE0_URL=http://localhost:2358
JUDGE0_AUTH_TOKEN=

# AI providers ---------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-pro

# Anti-Leak Engine -----------------------------------------------------------
SERPER_API_KEY=

# Auth -----------------------------------------------------------------------
# JWT_SECRET signs the recruiter session cookie (Surface 6, /v1/auth/login).
# HS256 — must be ≥32 chars and rotated only with a deliberate logout-all event.
JWT_SECRET=replace_me_with_long_random_string
# Lockout window (minutes) after 5 consecutive failed recruiter logins.
RECRUITER_LOCKOUT_MINUTES=15
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Mailer (Sprint 1.6) --------------------------------------------------------
# Driver-agnostic mailer for recruiter invitations (POST /v1/auth/invite).
# 'mock' records sends in memory (dev/test). Use 'ses' or 'sendgrid' in prod.
MAILER_DRIVER=mock
MAILER_FROM_ADDRESS=no-reply@qorium.io
MAILER_REPLY_TO_ADDRESS=
# Public URL of the recruiter portal (used to build invitation accept links).
RECRUITER_PORTAL_URL=http://localhost:5101
# AWS SES — required when MAILER_DRIVER=ses. If access keys are omitted, the
# AWS SDK default credential chain is used (IAM role on EC2/ECS).
SES_REGION=
SES_ACCESS_KEY_ID=
SES_SECRET_ACCESS_KEY=
# SendGrid — required when MAILER_DRIVER=sendgrid.
SENDGRID_API_KEY=

# Observability --------------------------------------------------------------
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
GRAFANA_CLOUD_API_KEY=

# Service ports (per infra/B10-ecosystem.config.js) --------------------------
READYBANK_PORT=5101         # qorium-api (cluster, 2 instances)
JDFORGE_PORT=5102           # qorium-jd-forge (cluster, 2 instances)
STACKVAULT_PORT=5103        # qorium-stack-vault (cluster, 2 instances)
ADMIN_PORT=5104             # qorium-admin (Next.js cluster)
# qorium-leak-crawler runs in fork mode; no HTTP port

# =============================================================================
# QOrium environment variables — example file
# Copy to .env and fill in real values. Never commit .env.
# =============================================================================

# Runtime --------------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=debug

# Postgres -------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=qorium
POSTGRES_USER=qorium
POSTGRES_PASSWORD=qorium_dev_password
DATABASE_URL=postgresql://qorium:qorium_dev_password@localhost:5432/qorium

# Redis ----------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Object storage (MinIO in dev, R2 in prod) ----------------------------------
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=qorium_dev_access
S3_SECRET_KEY=qorium_dev_secret
S3_BUCKET=qorium-dev

# Judge0 (code execution sandbox) --------------------------------------------
JUDGE0_URL=http://localhost:2358
JUDGE0_AUTH_TOKEN=

# AI providers ---------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-pro

# Anti-Leak Engine -----------------------------------------------------------
SERPER_API_KEY=

# Auth -----------------------------------------------------------------------
JWT_SECRET=replace_me_with_long_random_string
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Admin console (apps/admin) -------------------------------------------------
# AUTH_SECRET must be a long random string in prod; dev falls back to a stub.
AUTH_SECRET=
# Comma-separated list of admin emails permitted to sign in. Empty = no one.
ADMIN_EMAIL_ALLOWLIST=
# MSG91 (target provider per architecture §6.1) — leave blank until provisioned
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
MSG91_TEMPLATE_ID=

# Observability --------------------------------------------------------------
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
GRAFANA_CLOUD_API_KEY=

# Service ports (per infra/B10-ecosystem.config.js) --------------------------
READYBANK_PORT=5101         # qorium-api (cluster, 2 instances)
JDFORGE_PORT=5102           # qorium-jd-forge (cluster, 2 instances)
STACKVAULT_PORT=5103        # qorium-stack-vault (cluster, 2 instances)
ADMIN_PORT=5104             # qorium-admin (Next.js cluster)
# qorium-leak-crawler runs in fork mode; no HTTP port

# A4 assessment loop (qorium-my → candidate-portal → qorium-api) ------------
# A4_TOKEN_SECRET signs the stateless candidate invitation token (HMAC-SHA256).
# The SAME value must be present in the env of all three services (qorium-my,
# qorium-candidate-portal is render-only and does not sign, qorium-api/readybank
# verifies). Must be >= 32 chars. Rotating it invalidates all outstanding
# assessment links. Generate with: openssl rand -hex 32
A4_TOKEN_SECRET=replace_me_with_32plus_char_random_string
# Public base URL of the candidate portal; qorium-my builds assessment links
# against this. Production: https://candidate.qorium.online
CANDIDATE_PORTAL_BASE_URL=https://candidate.qorium.online
# Internal base URL of qorium-api/readybank; candidate-portal server routes
# call /a4/question and /a4/grade here. Loopback in single-host deploys.
QORIUM_API_BASE_URL=http://127.0.0.1:5101

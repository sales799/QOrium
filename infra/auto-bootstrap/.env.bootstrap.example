###############################################################################
# infra/auto-bootstrap/.env.bootstrap.example
#
# Template for the cred-drop file the CEO populates to authorize the
# autonomous CTO agent to APPLY the auto-bootstrap modules. Copy to
# .env.bootstrap (gitignored) and fill in. Until that file exists with
# BOOTSTRAP_AUTHORIZED=true, every module in this directory runs
# `terraform plan` only.
#
# The agent will NEVER read or modify this file. The wrapper script
# apply.sh refuses to run apply without it.
###############################################################################

###############################################################################
# Hard authorization gate — apply.sh refuses to apply unless this is
# exactly the literal string "true".
###############################################################################
BOOTSTRAP_AUTHORIZED=false

###############################################################################
# AWS credentials
#
# Two options — pick ONE:
#
#   Option A (recommended for daily use):  use a configured profile
#     # Leave AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY blank below and
#     # set AWS_PROFILE to a name configured in ~/.aws/credentials.
#     AWS_PROFILE=qorium-bootstrap-tf
#
#   Option B (CI / one-shot drops):  embed the keys directly
#     AWS_ACCESS_KEY_ID=AKIA…
#     AWS_SECRET_ACCESS_KEY=…
#
# Use a least-privilege IAM identity scoped to the resources each module
# touches. Never use root keys.
###############################################################################
AWS_PROFILE=qorium-bootstrap-tf
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

###############################################################################
# Region for SES + Route 53 records (Route 53 is global; the region
# only affects the SES identity and per-region MX target).
# ap-south-1 (Mumbai) recommended for Indian recipient inboxes per
# latency + DPDPA data-residency.
###############################################################################
QORIUM_AWS_REGION=ap-south-1

###############################################################################
# Apex domain (no scheme, no path).
#
# - For dns-zone.tf: this is the zone that will be CREATED in Route 53.
# - For email-auth.tf and other DNS-publishing modules: this zone must
#   already exist (use dns-zone.tf first if not).
###############################################################################
QORIUM_DOMAIN=qorium.online

###############################################################################
# Route 53 hosted zone ID (looks like Z0123456789ABCDEFGHIJ).
#
# Leave BLANK on the very first run if the zone doesn't exist yet —
# dns-zone.tf will create it and emit the zone_id as an output. After
# applying dns-zone, paste the output value here so email-auth.tf and
# other modules can attach DKIM / SPF / DMARC records.
###############################################################################
QORIUM_ROUTE53_ZONE_ID=

###############################################################################
# state-backend.tf — overrides
#
# QORIUM_STATE_BUCKET_NAME: blank → defaults to
#   qorium-terraform-state-<account_id>  (computed at apply time).
###############################################################################
QORIUM_STATE_BUCKET_NAME=
QORIUM_STATE_LOCK_TABLE=qorium-terraform-state-lock

###############################################################################
# email-auth.tf — DMARC reporting
#
# DMARC enforcement: start at quarantine; flip to reject after 14 days
# of clean reports.
###############################################################################
QORIUM_DMARC_POLICY=quarantine
QORIUM_DMARC_RUA=mailto:dmarc-rua@qorium.online
QORIUM_DMARC_RUF=mailto:dmarc-ruf@qorium.online

###############################################################################
# multi-region.tf — DR pair (Sprint 5.0)
###############################################################################
QORIUM_PRIMARY_REGION=ap-south-1
QORIUM_DR_REGION=ap-southeast-1
QORIUM_PRIMARY_CIDR=10.10.0.0/16
QORIUM_DR_CIDR=10.20.0.0/16
QORIUM_AUDIT_LOG_BUCKET_ARN=

###############################################################################
# pitr.tf — RDS PITR + cross-region backups
###############################################################################
QORIUM_RDS_CLUSTER_IDENTIFIER=qorium-primary
QORIUM_BACKUP_REGION=ap-southeast-1

###############################################################################
# observability.tf — Grafana Cloud + Sentry projects
#
# These are SECRETS. apply.sh will refuse to apply observability if
# these are empty AND BOOTSTRAP_AUTHORIZED=true.
###############################################################################
QORIUM_SENTRY_ORG_SLUG=qorium
QORIUM_SENTRY_AUTH_TOKEN=
QORIUM_GRAFANA_ORG_SLUG=qorium
QORIUM_GRAFANA_API_TOKEN=
QORIUM_GRAFANA_STACK_REGION=prod-ap-south-0

###############################################################################
# Recommended apply order (first-time bootstrap of an empty AWS account):
#
#   1. ./apply.sh state-backend     # creates S3 + DynamoDB for remote state
#   2. ./apply.sh dns-zone          # creates Route 53 zone for QORIUM_DOMAIN
#   3. <update domain registrar NS records to dns-zone output.name_servers>
#   4. <wait for DNS propagation (5–60 min); paste zone_id into QORIUM_ROUTE53_ZONE_ID above>
#   5. ./apply.sh email-auth        # SES + DKIM + SPF + DMARC
#   6. ./apply.sh pitr              # RDS backups
#   7. ./apply.sh multi-region      # DR pair
#   8. ./apply.sh observability     # Grafana + Sentry
#
# Each step is idempotent. Plan-only by default; flip
# BOOTSTRAP_AUTHORIZED=true above to apply.
###############################################################################

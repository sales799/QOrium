# QOrium production environment template
# Last updated: 2026-05-03 (Sprint 2.7)
#
# Copy to /opt/qorium/.env and fill in real values before pm2 start --env production.
# All values marked REQUIRED · HALT are CEO/CTO Office actions and cannot
# be auto-populated by the build agent.

NODE_ENV=production
LOG_LEVEL=info

# ---- Postgres ----
DATABASE_URL_PROD=                                # REQUIRED · HALT (Hostinger Postgres)

# ---- Redis ----
REDIS_URL=                                        # REQUIRED · HALT


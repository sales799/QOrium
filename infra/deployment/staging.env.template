# QOrium staging environment template
# Last updated: 2026-05-03 (Sprint 2.7)
#
# Copy to /opt/qorium-staging/.env and fill in real values before pm2 start.
# Lines marked REQUIRED must be set; the service will refuse to boot
# without them. Lines marked HALT are activation halts (CEO action).

# ---- Core ----
NODE_ENV=staging
LOG_LEVEL=info
GIT_SHA=                                 # populated by the deploy script

# ---- Postgres ----                     # REQUIRED · HALT
DATABASE_URL=postgres://qorium:CHANGE_ME@127.0.0.1:5432/qorium

# ---- Redis ----                        # REQUIRED · HALT
REDIS_URL=redis://localhost:6379

# ---- Service ports (per infra/B10-ecosystem.config.js) ----
READYBANK_PORT=5101
JD_FORGE_PORT=5102
STACK_VAULT_PORT=5103
ADMIN_PORT=5104
ATS_BRIDGE_PORT=5105
WEBHOOKS_PORT=5106
SSO_PORT=5107
DOCS_PORT=5108
JUDGE0_HEALTH_PORT=5109
TESTFORGE_HEALTH_PORT=5110
AUDIT_LOG_PORT=5111
BILLING_PORT=5112
API_KEY_MGMT_PORT=5113
UPTIME_PORT=5114
AI_PAIR_CODING_PORT=5115

# ---- API key hashing pepper ----       # REQUIRED · 32+ chars · HALT
API_KEY_PEPPER=CHANGE_ME_at_least_32_chars_random_value
API_KEY_CUSTOMER_ROTATION_DAYS=365
API_KEY_INTERNAL_ROTATION_DAYS=180

# ---- SSO ----                          # HALT (real IdP creds + RSA keypair)
SSO_BASE_URL=https://staging-api.qorium.online
SSO_JWT_AUDIENCE=https://staging-app.qorium.online
SSO_JWT_SIGNING_SECRET=CHANGE_ME_signing_secret_HS256
# SSO_JWT_ISSUER=  (defaults to SSO_BASE_URL)

# ---- Anthropic / OpenAI / Gemini ----  # HALT
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ---- Anti-leak crawler ----            # HALT
SERPER_API_KEY=

# ---- Judge0 ----                       # HALT
JUDGE0_URL=
JUDGE0_AUTH_TOKEN=
JUDGE0_POLL_INTERVAL_MS=500
JUDGE0_POLL_TIMEOUT_MS=60000
JUDGE0_MAX_RESPONSES_PER_RUN=100

# ---- Razorpay (billing) ----           # HALT
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
BILLING_DEFAULT_GST_BPS=1800
BILLING_DEFAULT_CURRENCY=INR

# ---- Webhooks delivery ----            # Sprint 2.4+ activation
WEBHOOKS_DELIVERY_TIMEOUT_MS=10000

# ---- Admin ----
NEXTAUTH_URL=https://staging-admin.qorium.online
NEXTAUTH_SECRET=CHANGE_ME_nextauth_secret
ADMIN_EMAIL_ALLOWLIST=ops@qorium.online,cto@qorium.online
ADMIN_DEFAULT_TENANT_ID=11111111-2222-3333-4444-555555555555

# ---- Observability (Sprint 2.9) ----   # HALT
SENTRY_DSN=
GRAFANA_LOKI_URL=
GRAFANA_LOKI_TOKEN=

# ---- Talpro Sentinel webhook ----      # HALT
TALPRO_SENTINEL_WEBHOOK_URL=

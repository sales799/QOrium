# Side-deploy env for /opt/qorium-mailer/.env
# Copy this to /opt/qorium-mailer/.env and fill in the bracketed values.
# DO NOT commit .env. The deploy.sh script copies this file as a starting
# point if no .env exists yet.

NODE_ENV=production
LOG_LEVEL=info

# ----------------------------------------------------------------------------
# Postgres — separate database from the running qorium-api
# ----------------------------------------------------------------------------
# Reuses the existing local postgres host/port/role; just a different DB name.
# deploy.sh creates this DB and applies all migrations from main.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=qorium_mailer
POSTGRES_USER=qorium
POSTGRES_PASSWORD=[copy from /opt/qorium/.env POSTGRES_PASSWORD]
DATABASE_URL=postgresql://qorium:[same password]@localhost:5432/qorium_mailer

# ----------------------------------------------------------------------------
# Redis — share with the main qorium-api (rate limiting + session)
# ----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ----------------------------------------------------------------------------
# Service port — must NOT collide with qorium-api (5101) or any other service
# ----------------------------------------------------------------------------
READYBANK_PORT=5150

# ----------------------------------------------------------------------------
# JWT — must be the SAME secret as /opt/qorium/.env so accept-invite-issued
# session cookies are accepted by both clusters if a recruiter happens to
# land on either side. (Today nginx routes by URL so this is belt+braces.)
# ----------------------------------------------------------------------------
JWT_SECRET=[copy from /opt/qorium/.env JWT_SECRET]
RECRUITER_LOCKOUT_MINUTES=15

# ----------------------------------------------------------------------------
# Mailer — the whole point of this side-deploy
# ----------------------------------------------------------------------------
MAILER_DRIVER=ses
MAILER_FROM_ADDRESS=noreply@qorium.online
MAILER_REPLY_TO_ADDRESS=bhaskar@talpro.in
RECRUITER_PORTAL_URL=https://my.qorium.online

# AWS SES creds (region ap-south-1; production access is denied — sandbox only)
SES_REGION=ap-south-1
SES_ACCESS_KEY_ID=[paste from your AWS bootstrap secrets]
SES_SECRET_ACCESS_KEY=[paste from your AWS bootstrap secrets]

# SendGrid alternative — if SES sandbox is too limiting, swap MAILER_DRIVER=sendgrid
# and uncomment+fill SENDGRID_API_KEY. Same route, same template, no code change.
# SENDGRID_API_KEY=

# ----------------------------------------------------------------------------
# API-key gate (admin invite endpoint authentication)
# ----------------------------------------------------------------------------
# The pepper that hashes API keys before lookup. MUST match the pepper used
# when the keys were originally created on /opt/qorium. Copy from there.
API_KEY_PEPPER=[copy from /opt/qorium/.env API_KEY_PEPPER]

# ----------------------------------------------------------------------------
# Cookie scope — set to true in production behind nginx HTTPS
# ----------------------------------------------------------------------------
COOKIE_SECURE=true

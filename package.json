{
  "name": "qorium",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "QOrium — role-graph-native Question-Bank-as-a-Service",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build:packages": "pnpm --filter @qorium/db --filter @qorium/auth run build",
    "typecheck": "pnpm run build:packages && pnpm -r --if-present run typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm run build:packages && pnpm -r --if-present run test",
    "build": "pnpm -r --if-present run build",
    "deploy": "/usr/local/bin/safe-deploy qorium-web-v2-preview",
    "deploy:atomic": "/usr/local/bin/safe-deploy qorium-web-v2-preview",
    "deploy:atomic:raw": "TALPRO_GBS_RAW_DEPLOY=1 bash redeploy-preview.sh",
    "secrets:scan": "gitleaks detect --source . --no-banner --redact || (echo 'gitleaks not installed — see README' && exit 1)",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "husky": "^9.1.6",
    "lint-staged": "^17.0.7",
    "prettier": "^3.3.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "argon2",
      "esbuild"
    ]
  }
}

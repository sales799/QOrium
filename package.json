{
  "name": "qorium",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "QOrium — role-graph-native Question-Bank-as-a-Service",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "typecheck": "pnpm run build:packages && pnpm -r --if-present run typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm run build:packages && pnpm -r --if-present run test",
    "build": "pnpm -r --if-present run build",
    "deploy": "/usr/local/bin/safe-deploy qorium-marketing",
    "deploy:atomic": "/usr/local/bin/safe-deploy qorium-marketing",
    "deploy:atomic:raw": "TALPRO_GBS_RAW_DEPLOY=1 bash infra/marketing-deploy.sh",
    "dev:marketing": "pnpm --filter @qorium/marketing dev",
    "secrets:scan": "gitleaks detect --source . --no-banner --redact || (echo 'gitleaks not installed — see README' && exit 1)",
    "prepare": "husky",
    "build:packages": "pnpm --filter @qorium/db --filter @qorium/auth run build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "husky": "^9.1.6",
    "lint-staged": "^17.0.5",
    "prettier": "^3.3.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,mdx,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "brace-expansion": "^5.0.6",
      "esbuild": "^0.25.0",
      "postcss": "^8.5.10",
      "qs": "^6.15.2",
      "vite": "^6.4.2"
    }
  }
}

{
  "name": "@qorium/my",
  "version": "0.0.0",
  "private": true,
  "description": "QOrium customer self-service portal (my.qorium.online). Listens on :5118. Invoice list + payment intent + subscription overview + API key issuance/rotation. Reuses @qorium/qorium-sdk.",
  "scripts": {
    "build": "next build",
    "dev": "next dev --port 5118",
    "start": "next start --port 5118",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@qorium/sdk": "workspace:*",
    "next": "15.0.4",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/react": "19.0.1",
    "@types/react-dom": "19.0.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}

# Public site URL (used by sitemap, OG tags, JSON-LD).
NEXT_PUBLIC_SITE_URL=https://qorium.online

# Plausible analytics — leave empty until configured.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=qorium.online

# Email dispatch — Resend is preferred. Without these, contact form falls back
# to Gmail SMTP (below) or to console-log + mailto link.
RESEND_API_KEY=
CONTACT_TO_EMAIL=hello@qorium.online
CONTACT_FROM_EMAIL=noreply@qorium.online

# Gmail SMTP fallback (only used if RESEND_API_KEY is not set).
# GMAIL_USER=
# GMAIL_APP_PASSWORD=

# Optional: Upstash Redis for rate limiting. If absent, an in-memory throttle is used.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

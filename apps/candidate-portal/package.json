{
  "name": "@qorium/candidate-portal",
  "version": "0.0.0",
  "private": true,
  "description": "QOrium candidate assessment portal. Listens on :5116.",
  "scripts": {
    "build": "next build",
    "dev": "next dev --port 5116",
    "start": "node .next/standalone/apps/candidate-portal/server.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf .next out node_modules/.cache"
  },
  "dependencies": {
    "next": "^15.5.18",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.17.12",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}

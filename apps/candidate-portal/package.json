{
  "name": "@qorium/candidate-portal",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "QOrium candidate portal (Wave 3 AI pair-coding UX). Listens on :5116. Per infra/Wave-3-AI-Pair-Coding-Format-Prototype-Spec-v0.md §2.1 + §2.2.",
  "scripts": {
